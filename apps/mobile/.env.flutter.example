# ─── PSGMX Flutter App — Environment Variables ───────────────────────────────
# Copy this file to .env.flutter (gitignored) and fill in real values.
# Usage: flutter run --dart-define-from-file=.env.flutter
#        flutter build apk --dart-define-from-file=.env.flutter
#
# NEVER commit .env.flutter to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Supabase project URL (Settings → API → Project URL)
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (Settings → API → anon public)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL of the eCampus FastAPI scraper (your Python service deployment)
ECAMPUS_API_URL=https://your-ecampus-api.example.com

# Shared secret between the Flutter app and the eCampus API
# Generate with: openssl rand -hex 32
ECAMPUS_API_SECRET=change-me-to-a-long-random-string

# API key for pushing readiness scores to the external desktop exam platform
EXTERNAL_PLATFORM_API_KEY=

# OpenRouter API key for the AI Mentor feature (https://openrouter.ai)
OPENROUTER_API_KEY=
